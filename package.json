{
  "name": "github-triage-bot",
  "version": "1.5.0",
  "private": true,
  "description": "Config-driven GitHub triage bot for issues and pull requests",
  "type": "module",
  "scripts": {
    "build": "ncc build src/triage-bot.js -o dist",
    "run": "node src/triage-bot.js",
    "validate-config": "node src/triage-bot.js --validate-config"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "js-yaml": "^4.1.0",
    "minimatch": "^10.2.5"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.3"
  }
}
